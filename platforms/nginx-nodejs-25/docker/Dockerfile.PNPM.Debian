# Stage 1: Pull official Node binaries matching Debian Bookworm's glibc environment
FROM node:24-bookworm-slim AS node-binaries
FROM debian:bookworm-slim

ARG UID=1000
ARG GID=1000
ARG USER=appuser
ARG GROUP=appgroup

ENV UID=${UID}
ENV GID=${GID}
ENV USER=${USER}
ENV GROUP=${GROUP}

# Install Debian utilities
RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    sudo \
    curl \
    wget \
    openssl \
    nginx \
    zip \
    nano \
    git \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Create system group and user utilizing native Debian shadow-utils syntax
RUN groupadd -g ${GID} ${GROUP} \
    && useradd -u ${UID} -m -d /home/${USER} -s /bin/bash -g ${GROUP} ${USER} \
    && chmod u+s /bin/su \
    && echo "${USER} ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Map the verified NodeJS 24 environment from Stage 1 into native paths
COPY --from=node-binaries /usr/local/include /usr/local/include
COPY --from=node-binaries /usr/local/lib /usr/local/lib
COPY --from=node-binaries /usr/local/bin /usr/local/bin

# 1. Force link core node engines FIRST so Corepack can detect them safely
RUN ln -s /usr/local/bin/node /usr/bin/node \
    && ln -s /usr/local/bin/npm /usr/bin/npm \
    && ln -s /usr/local/bin/npx /usr/bin/npx

# 2. Enable Corepack and prepare pnpm natively
RUN corepack enable && corepack prepare pnpm@latest --activate

# 3. Create a global symlink for pnpm so Supervisor and other root tools can find it
RUN ln -s /usr/local/bin/pnpm /usr/bin/pnpm \
    && ln -s /usr/local/bin/pnpx /usr/bin/pnpx

# Verify installations during the build phase
RUN node -v && npm -v && pnpm -v

# Configure NGINX (Removes standard boilerplate definitions safely)
COPY config/nginx/nginx.conf /etc/nginx/nginx.conf
COPY config/nginx/conf.d /etc/nginx/conf.d/

# Configure Supervisord
COPY config/supervisor/supervisord.conf /etc/supervisor/supervisord.conf
COPY config/supervisor/conf.d/. /etc/supervisor/conf.d/

# Create project root
RUN mkdir -p /var/www
WORKDIR /var/www

# Copy files and fix permissions immediately
COPY --chown=${USER}:${GROUP} . /var/www

# Clean up default server directories if they were initialized by APT
RUN rm -rf /var/www/html /var/www/localhost

# Ensure Debian runtime/PID folders exist and are writable by your custom non-root user
RUN mkdir -p /run /var/lib/nginx /var/log/nginx /var/log/supervisor /var/run/supervisor \
    && chown -R ${USER}:${GROUP} /var/www /run /var/lib/nginx /var/log/nginx /var/log/supervisor /var/run/supervisor

# Switch to non-root user execution
USER ${USER}

# Configure pnpm home and path variables for the non-root user's execution scope
ENV PNPM_HOME="/home/${USER}/.local/share/pnpm"
ENV PATH="${PNPM_HOME}:${PATH}"

EXPOSE 80 3000 8080

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]